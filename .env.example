# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"

# Database
DATABASE_URL="postgresql://postgres"

# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="anon-key-for-supabase" # Replace with your actual anon key from Supabase. This can be exposed to the client.

SUPABASE_SERVICE_ROLE_KEY="key-for-service-role" # Replace with your actual service role key from Supabase. This should be kept secret and not exposed to the client.

# Browser-safe Supabase values.
# These are exposed to the client because they use the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"

# Supabase Storage buckets
SUPABASE_STORAGE_BUCKET_ORIGINAL="original-pdfs"
SUPABASE_STORAGE_BUCKET_PROCESSED="processed-pdfs"

# Upload limits
# Must be a positive integer no greater than 100.
MAX_PDF_SIZE_MB="10"


NEXT_PUBLIC_SUPABASE_URL=supabase-url-for-client
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key-for-client"