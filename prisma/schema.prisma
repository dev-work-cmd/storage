/// Owns the canonical database schema for the application.
/// Balances the product-domain models with the tables Better Auth requires next stage.
/// Keeps document fields ahead of later QR and access-policy stages without implementing those flows yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Roles stay as an enum because authorization branches on a closed set of values.
enum UserRole {
  OWNER
  TRUSTED_USER
}

/// Document lifecycle stays enum-backed so dashboard counts and processing branches remain explicit.
enum DocumentStatus {
  DRAFT
  PROCESSING
  PROCESSED
  FAILED
}

/// Public QR behavior is a closed set that later verification and streaming routes will enforce.
enum QrMode {
  VERIFY
  OPEN
  DOWNLOAD
}

/// Audit events remain explicit to keep security logging queryable and consistent.
enum AuditEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  DOCUMENT_UPLOADED
  QR_DETECTION_SUCCESS
  QR_DETECTION_FAILURE
  QR_MANUAL_SELECTION
  DOCUMENT_PROCESSED
  DOCUMENT_OPENED
  DOCUMENT_DOWNLOADED
  DOCUMENT_REVOKED
  DOCUMENT_DELETED
  ACCESS_ALLOWED
  ACCESS_DENIED
}

/// Audit outcomes are enum-backed because the app only needs a constrained result set.
enum AuditOutcome {
  INFO
  SUCCESS
  FAILURE
}

model User {
  id              String   @id @default(cuid())
  username        String   @unique
  displayUsername String?
  name            String?
  email           String   @unique
  emailVerified   Boolean  @default(false)
  image           String?
  role            UserRole @default(OWNER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  passkeys  Passkey[]
  documents Document[]
  auditLogs AuditLog[]
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Passkey {
  id           String   @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  credentialID String   @unique
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime @default(now())
  aaguid       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkey")
}

model Document {
  id                     String         @id @default(cuid())
  publicId               String         @unique @default(cuid())
  ownerId                String
  title                  String
  originalFilename       String
  originalMimeType       String         @default("application/pdf")
  originalFilePath       String?
  processedFilePath      String?
  status                 DocumentStatus @default(DRAFT)
  processingError        String?
  qrMode                 QrMode         @default(VERIFY)
  qrTargetUrl            String?
  qrPageNumber           Int?
  qrX                    Decimal?       @db.Decimal(12, 4)
  qrY                    Decimal?       @db.Decimal(12, 4)
  qrWidth                Decimal?       @db.Decimal(12, 4)
  qrHeight               Decimal?       @db.Decimal(12, 4)
  expiresAt              DateTime?
  maxAccessCount         Int?
  accessCount            Int            @default(0)
  scanCount              Int            @default(0)
  openCount              Int            @default(0)
  downloadCount          Int            @default(0)
  accessSuccessCount     Int            @default(0)
  accessFailureCount     Int            @default(0)
  requiresPin            Boolean        @default(false)
  pinHash                String?
  legalConfirmedAt       DateTime?
  isEnabled              Boolean        @default(true)
  isRevoked              Boolean        @default(false)
  revokedAt              DateTime?
  processedAt            DateTime?
  lastAccessedAt         DateTime?
  encryptionEnabled      Boolean        @default(false)
  encryptedOriginalPath  String?
  encryptedProcessedPath String?
  encryptionIv           String?
  encryptionAuthTag      String?
  encryptedDataKey       String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([publicId, isRevoked, isEnabled])
}

model AuditLog {
  id          String       @id @default(cuid())
  actorUserId String?
  documentId  String?
  event       AuditEvent
  outcome     AuditOutcome @default(INFO)
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  actor    User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([documentId, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
}
